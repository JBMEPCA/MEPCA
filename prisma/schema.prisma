// Cogent Hub — data model
// Plain-English guide:
//   Magazine             = one of the five Cogent Multimedia titles; every
//                          record below belongs to exactly one magazine
//   Campaign             = a booked ad campaign (the tracker)
//   PipelineItem         = a pitched campaign awaiting sign-off (the pipeline)
//   FollowUpReminder     = a dated nudge attached to a pipeline item or campaign
//   CompetitorAdvertiser = a brand seen advertising in a competitor title
//                          (imported from the Lead Sourcing spreadsheet)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (port 6543) — used by the app
  directUrl = env("DIRECT_URL") // session connection (port 5432) — used for migrations
}

// One of the five titles. The id IS the URL slug ("mepca", "hotel", "bar",
// "care-home", "grooming") so pages can use route params directly as keys.
// Display-only details (logo, brand colour, sector wording, WordPress env
// keys) live in lib/magazines.ts — the DB row exists for FK integrity.
model Magazine {
  id        String  @id // slug, e.g. "mepca"
  name      String // display name, e.g. "MEPCA"
  siteUrl   String
  sortOrder Int     @default(0)
  active    Boolean @default(true)

  campaigns             Campaign[]
  pipelineItems         PipelineItem[]
  issueDeadlines        IssueDeadline[]
  watchedSources        WatchedSource[]
  competitorAdvertisers CompetitorAdvertiser[]
  monitoredTerms        MonitoredTerm[]
  googleAdsLeads        GoogleAdsLead[]
  sitePages             SitePage[]
  siteCrawls            SiteCrawl[]
}

enum CampaignStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model Campaign {
  id          String         @id @default(cuid())
  magazine    Magazine       @relation(fields: [magazineId], references: [id])
  magazineId  String
  brand       String
  package     String // package/spec booked, e.g. "Full page + web banner"
  value       Decimal?       @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  status      CampaignStatus @default(UPCOMING)
  notes       String?
  saleDate    DateTime? // when the booking was made (drives the Sales page)
  issue       String? // which issue it runs in, e.g. "Dec 2023"
  salesperson String? // who made the sale (from FileMaker's Sales Person column)
  contentReceived Boolean @default(false) // artwork/content in hand — the chase tick
  fileMakerId String? // stable key so FileMaker re-imports update instead of duplicate
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reminders FollowUpReminder[]

  // FileMaker record ids are only unique within one magazine's FileMaker file
  @@unique([magazineId, fileMakerId])
  @@index([magazineId])
}

// Per-issue production deadlines parsed from the Deadlines spreadsheet
model IssueDeadline {
  id            String    @id @default(cuid())
  magazine      Magazine  @relation(fields: [magazineId], references: [id])
  magazineId    String
  issue         String // e.g. "February 2026"
  issueDate     DateTime // first of the issue month, for sorting
  salesDeadline DateTime?
  adsDeadline   DateTime? // "100% ADS" — all ad content in hand
  printDate     DateTime?
  createdAt     DateTime  @default(now())

  @@unique([magazineId, issue])
}

enum PipelineStage {
  PITCHED
  PROPOSAL_SENT
  NEGOTIATING
  VERBAL_AGREEMENT
  SIGNED_OFF
  LOST
}

model PipelineItem {
  id             String        @id @default(cuid())
  magazine       Magazine      @relation(fields: [magazineId], references: [id])
  magazineId     String
  brand          String
  package        String?
  estimatedValue Decimal?      @db.Decimal(10, 2)
  stage          PipelineStage @default(PITCHED)
  followUpDate   DateTime?
  salesperson    String? // who owns the pitch
  notes          String?
  // set when the pitch is won and converted into a Campaign
  convertedCampaignId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  reminders FollowUpReminder[]

  @@index([magazineId])
}

model FollowUpReminder {
  id      String   @id @default(cuid())
  dueDate DateTime
  note    String?
  done    Boolean  @default(false)

  pipelineItem   PipelineItem? @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  pipelineItemId String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId     String?

  createdAt DateTime @default(now())
}

// A competitor website or magazine archive the automated watcher checks
enum SourceType {
  WEBSITE // scan pages for display/banner ads
  PDF_ARCHIVE // watch for new issues with direct PDF downloads
  FLIPBOOK // watch for new issues, but alert JB to run the skill manually
}

// Live state the Agent HQ spy animation reads
enum ScanStatus {
  IDLE
  QUEUED
  SCANNING
}

model WatchedSource {
  id            String     @id @default(cuid())
  magazine      Magazine   @relation(fields: [magazineId], references: [id])
  magazineId    String
  name          String // competitor title, e.g. "Warehouse & Logistics News"
  type          SourceType
  url           String
  active        Boolean    @default(true)
  scanStatus    ScanStatus @default(IDLE)
  lastCheckedAt DateTime?
  lastResult    String? // human-readable summary of the last scan
  // URLs of issues/PDFs already processed, so we only handle new ones
  seenItems     String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  alerts SourceAlert[]
}

// "New issue is out" / "PDF too large" notices the watcher raises for JB
model SourceAlert {
  id        String        @id @default(cuid())
  source    WatchedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId  String
  message   String
  url       String?
  dismissed Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model CompetitorAdvertiser {
  id                 String   @id @default(cuid())
  magazine           Magazine @relation(fields: [magazineId], references: [id])
  magazineId         String
  brand              String
  competitorMagazine String
  adType             String?
  whereFound         String?
  confidenceNotes    String?
  source             String?
  goodTarget         Boolean  @default(false) // flagged by JB as worth pitching
  pitched            Boolean  @default(false) // already contacted / in pipeline
  // normalised "brand|magazine|adType" — lets spreadsheet re-imports update rows
  // instead of duplicating them
  dedupeKey          String
  firstSeenAt        DateTime @default(now())
  lastImportedAt     DateTime @default(now())

  @@unique([magazineId, dedupeKey])
}

// ---------- Google Ads Leads ("Sniper" agent) ----------
// A search term the Sniper agent googles (UK-targeted) to see who is paying
// for Google Ads on it. Seeded from the WordPress CATEGORIES list.

// Live state the Sniper HQ animation reads (mirrors ScanStatus for the spy)
enum AdSearchStatus {
  IDLE
  QUEUED
  SEARCHING
}

model MonitoredTerm {
  id           String         @id @default(cuid())
  magazine     Magazine       @relation(fields: [magazineId], references: [id])
  magazineId   String
  term         String // the Google query, e.g. "manufacturing software"
  category     String? // WordPress category it was seeded from, if any
  active       Boolean        @default(true)
  searchStatus AdSearchStatus @default(IDLE)
  lastCheckedAt DateTime?
  lastResult   String? // human-readable summary of the last search
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  leads GoogleAdsLead[]

  // two magazines may legitimately monitor the same term
  @@unique([magazineId, term])
}

// A company caught running a Google Ad on one of the monitored terms —
// a prospective advertiser for MEPCA to pitch.
model GoogleAdsLead {
  id            String   @id @default(cuid())
  magazine      Magazine @relation(fields: [magazineId], references: [id])
  magazineId    String
  company       String // advertiser name (from the ad's displayed source)
  website       String? // destination / displayed domain
  adHeadline    String? // the ad's headline text
  adDescription String? // the ad's body copy
  term          MonitoredTerm @relation(fields: [termId], references: [id], onDelete: Cascade)
  termId        String
  searchTerm    String // denormalised term text, for display + filtering
  goodTarget    Boolean  @default(false) // flagged by JB as worth pitching
  pitched       Boolean  @default(false) // already contacted / in pipeline
  // normalised "company|term" — one row per advertiser per term, updated on re-search
  dedupeKey     String
  timesSeen     Int      @default(1) // how many searches this advertiser has shown up in
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  @@unique([magazineId, dedupeKey])
}

// ---------- Internal Link Map ----------
// A snapshot of the magazine website's pages and the in-content links between
// them, feeding the 3D "Internal Linking Map" tab. Rebuilt by each crawl.

model SitePage {
  id         String    @id @default(cuid())
  magazine   Magazine  @relation(fields: [magazineId], references: [id])
  magazineId String
  url        String // normalised full URL (no www, no trailing slash)
  path       String // pathname shown in the UI, e.g. "/advertise-with-us"
  title      String?
  kind       String // "page" | "post" | "company", from which Yoast sitemap listed it
  httpStatus Int?
  crawledAt  DateTime?

  linksOut SiteLink[] @relation("linkSource")
  linksIn  SiteLink[] @relation("linkTarget")

  @@unique([magazineId, url])
  @@index([magazineId])
}

// One in-content hyperlink from one crawled page to another
model SiteLink {
  id         String   @id @default(cuid())
  magazineId String
  from       SitePage @relation("linkSource", fields: [fromId], references: [id], onDelete: Cascade)
  fromId     String
  to         SitePage @relation("linkTarget", fields: [toId], references: [id], onDelete: Cascade)
  toId       String

  @@unique([fromId, toId])
  @@index([magazineId])
}

enum CrawlStatus {
  QUEUED
  RUNNING
  DONE
  ERROR
}

// Progress/state of one crawl run — the tab polls this for its progress bar
model SiteCrawl {
  id           String      @id @default(cuid())
  magazine     Magazine    @relation(fields: [magazineId], references: [id])
  magazineId   String
  status       CrawlStatus @default(QUEUED)
  totalPages   Int         @default(0)
  crawledPages Int         @default(0)
  error        String?
  startedAt    DateTime    @default(now())
  finishedAt   DateTime?

  @@index([magazineId])
}
