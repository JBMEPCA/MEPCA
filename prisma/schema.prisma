// MEPCA Hub — data model
// Plain-English guide:
//   Campaign             = a booked ad campaign (the tracker)
//   PipelineItem         = a pitched campaign awaiting sign-off (the pipeline)
//   FollowUpReminder     = a dated nudge attached to a pipeline item or campaign
//   CompetitorAdvertiser = a brand seen advertising in a competitor title
//                          (imported from the Lead Sourcing spreadsheet)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (port 6543) — used by the app
  directUrl = env("DIRECT_URL") // session connection (port 5432) — used for migrations
}

enum CampaignStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model Campaign {
  id          String         @id @default(cuid())
  brand       String
  package     String // package/spec booked, e.g. "Full page + web banner"
  value       Decimal?       @db.Decimal(10, 2)
  startDate   DateTime?
  endDate     DateTime?
  status      CampaignStatus @default(UPCOMING)
  notes       String?
  saleDate    DateTime? // when the booking was made (drives the Sales page)
  issue       String? // which issue it runs in, e.g. "Dec 2023"
  fileMakerId String?        @unique // stable key so FileMaker re-imports update instead of duplicate
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reminders FollowUpReminder[]
}

// Per-issue production deadlines parsed from the Deadlines spreadsheet
model IssueDeadline {
  id            String    @id @default(cuid())
  issue         String    @unique // e.g. "February 2026"
  issueDate     DateTime // first of the issue month, for sorting
  salesDeadline DateTime?
  adsDeadline   DateTime? // "100% ADS" — all ad content in hand
  printDate     DateTime?
  createdAt     DateTime  @default(now())
}

enum PipelineStage {
  PITCHED
  PROPOSAL_SENT
  NEGOTIATING
  VERBAL_AGREEMENT
  SIGNED_OFF
  LOST
}

model PipelineItem {
  id             String        @id @default(cuid())
  brand          String
  package        String?
  estimatedValue Decimal?      @db.Decimal(10, 2)
  stage          PipelineStage @default(PITCHED)
  followUpDate   DateTime?
  notes          String?
  // set when the pitch is won and converted into a Campaign
  convertedCampaignId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  reminders FollowUpReminder[]
}

model FollowUpReminder {
  id      String   @id @default(cuid())
  dueDate DateTime
  note    String?
  done    Boolean  @default(false)

  pipelineItem   PipelineItem? @relation(fields: [pipelineItemId], references: [id], onDelete: Cascade)
  pipelineItemId String?
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId     String?

  createdAt DateTime @default(now())
}

// A competitor website or magazine archive the automated watcher checks
enum SourceType {
  WEBSITE // scan pages for display/banner ads
  PDF_ARCHIVE // watch for new issues with direct PDF downloads
  FLIPBOOK // watch for new issues, but alert JB to run the skill manually
}

// Live state the Agent HQ spy animation reads
enum ScanStatus {
  IDLE
  QUEUED
  SCANNING
}

model WatchedSource {
  id            String     @id @default(cuid())
  name          String // competitor title, e.g. "Warehouse & Logistics News"
  type          SourceType
  url           String
  active        Boolean    @default(true)
  scanStatus    ScanStatus @default(IDLE)
  lastCheckedAt DateTime?
  lastResult    String? // human-readable summary of the last scan
  // URLs of issues/PDFs already processed, so we only handle new ones
  seenItems     String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  alerts SourceAlert[]
}

// "New issue is out" / "PDF too large" notices the watcher raises for JB
model SourceAlert {
  id        String        @id @default(cuid())
  source    WatchedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId  String
  message   String
  url       String?
  dismissed Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model CompetitorAdvertiser {
  id                 String   @id @default(cuid())
  brand              String
  competitorMagazine String
  adType             String?
  whereFound         String?
  confidenceNotes    String?
  source             String?
  goodTarget         Boolean  @default(false) // flagged by JB as worth pitching
  pitched            Boolean  @default(false) // already contacted / in pipeline
  // normalised "brand|magazine|adType" — lets spreadsheet re-imports update rows
  // instead of duplicating them
  dedupeKey          String   @unique
  firstSeenAt        DateTime @default(now())
  lastImportedAt     DateTime @default(now())
}
